{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MINDI",
  "version": "0.1.0",
  "identifier": "com.mindi.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MINDI",
        "url": "index.html",
        "width": 1200,
        "height": 860,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "orb",
        "title": "MINDI Orb",
        "url": "orb.html",
        "width": 72,
        "height": 72,
        "alwaysOnTop": true,
        "transparent": true,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "visible": true,
        "center": false,
        "x": 100,
        "y": 100
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
