{
  "name": "mindi",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:desktop": "pnpm --dir apps/desktop dev",
    "build:desktop": "pnpm --dir apps/desktop build",
    "dev:agent": "python -m uvicorn mindi_agent.main:app --reload --host 127.0.0.1 --port 8765 --app-dir services/agent/src",
    "test:agent": "python -m pytest services/agent/tests"
  }
}

