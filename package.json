{
  "name": "mindi",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:desktop": "pnpm --dir apps/desktop dev",
    "build:desktop": "pnpm --dir apps/desktop build",
    "dev:agent": "python -m uvicorn mindi_agent.main:app --reload --host 127.0.0.1 --port 8765 --app-dir services/agent/src",
    "dev:all": "concurrently -k -n AGENT,DESKTOP -c blue,magenta \"pnpm dev:agent\" \"pnpm dev:desktop\"",
    "test:agent": "python -m pytest services/agent/tests",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "ci:check": "pnpm test:agent && pnpm build:desktop && pnpm test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.2.1"
  }
}
